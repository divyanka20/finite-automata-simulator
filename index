<script>
// ================== STATE ==================
let mode = 'DFA'; // 'DFA' or 'NFA'
let states = []; // [{id, name, isStart, isAccept, x, y}]
let transitions = []; // [{from, symbol, to}]
let selectedState = null;
let editingStateId = null;
let currentTool = 'select';
let stateIdCounter = 0;

// Simulation
let simInput = '';
let simStep = 0;
let simActive = false;
let simLog = [];
let autoplayTimer = null;
let nfaCurrentStates = new Set();
let dfaCurrentState = null;

// D3
let svg, g, width, height;
let simulation;
let nodeData = [], edgeData = [];

// ================== INIT ==================
function init() {
  svg = d3.select('#fa-canvas');
  const rect = document.getElementById('fa-canvas').getBoundingClientRect();
  width = rect.width;
  height = rect.height;

  // Canvas click to add state
  svg.on('click', function(event) {
    if (event.target !== this && event.target.tagName === 'svg') return;
    if (currentTool !== 'select') return;
    const [x, y] = d3.pointer(event);
    if (event.target.tagName === 'svg' || event.target.tagName === 'rect') {
      // Only add if clicking empty space
    }
  });

  svg.on('dblclick', function(event) {
    if (event.target.tagName !== 'svg') return;
    const [x, y] = d3.pointer(event);
    quickAddState(x, y);
  });

  // Main container
  g = svg.append('g').attr('class', 'main-g');

  // Zoom
  const zoom = d3.zoom()
    .scaleExtent([0.2, 3])
    .on('zoom', (event) => {
      g.attr('transform', event.transform);
    });
  svg.call(zoom);

  renderGraph();
  updateUI();
}

// ================== MODE ==================
function setMode(m) {
  mode = m;
  document.getElementById('dfa-mode-btn').classList.toggle('active', m === 'DFA');
  document.getElementById('nfa-mode-btn').classList.toggle('active', m === 'NFA');
  document.getElementById('nfa-trans-info').classList.toggle('hidden', m === 'DFA');
  document.getElementById('eps-hint').classList.toggle('hidden', m === 'DFA');
  resetSim();
  updateUI();
}

// ================== STATES ==================
function openAddStateModal() {
  document.getElementById('new-state-name').value = `q${stateIdCounter}`;
  document.getElementById('new-state-start').checked = states.length === 0;
  document.getElementById('new-state-accept').checked = false;
  openModal('add-state-modal');
  setTimeout(() => document.getElementById('new-state-name').select(), 50);
}

function confirmAddState() {
  const name = document.getElementById('new-state-name').value.trim();
  if (!name) return;
  if (states.find(s => s.name === name)) { alert('State name already exists'); return; }

  const isStart = document.getElementById('new-state-start').checked;
  const isAccept = document.getElementById('new-state-accept').checked;

  if (isStart) states.forEach(s => s.isStart = false);

  const rect = document.getElementById('fa-canvas').getBoundingClientRect();
  const cx = rect.width / 2 + (Math.random() - 0.5) * 200;
  const cy = rect.height / 2 + (Math.random() - 0.5) * 150;

  states.push({ id: stateIdCounter++, name, isStart, isAccept, x: cx, y: cy });
  closeModal('add-state-modal');
  renderGraph();
  updateUI();
}

function quickAddState(x, y) {
  const name = `q${stateIdCounter}`;
  const isStart = states.length === 0;
  states.push({ id: stateIdCounter++, name, isStart: isStart, isAccept: false, x, y });
  renderGraph();
  updateUI();
}

function deleteState(id) {
  states = states.filter(s => s.id !== id);
  transitions = transitions.filter(t => t.from !== id && t.to !== id);
  renderGraph();
  updateUI();
}

function openEditState(id) {
  const s = states.find(st => st.id === id);
  if (!s) return;
  editingStateId = id;
  document.getElementById('edit-state-name').value = s.name;
  document.getElementById('edit-state-start').checked = s.isStart;
  document.getElementById('edit-state-accept').checked = s.isAccept;
  openModal('edit-state-modal');
  setTimeout(() => document.getElementById('edit-state-name').select(), 50);
}

function confirmEditState() {
  const name = document.getElementById('edit-state-name').value.trim();
  if (!name) return;
  if (states.find(s => s.name === name && s.id !== editingStateId)) { alert('Name exists'); return; }

  const s = states.find(st => st.id === editingStateId);
  if (!s) return;

  const wasStart = s.isStart;
  s.name = name;
  s.isStart = document.getElementById('edit-state-start').checked;
  s.isAccept = document.getElementById('edit-state-accept').checked;

  if (s.isStart && !wasStart) states.forEach(st => { if (st.id !== s.id) st.isStart = false; });

  closeModal('edit-state-modal');
  renderGraph();
  updateUI();
}

function toggleStart(id) {
  const s = states.find(st => st.id === id);
  if (!s) return;
  states.forEach(st => st.isStart = false);
  s.isStart = true;
  renderGraph();
  updateUI();
}

function toggleAccept(id) {
  const s = states.find(st => st.id === id);
  if (!s) return;
  s.isAccept = !s.isAccept;
  renderGraph();
  updateUI();
}

// ================== TRANSITIONS ==================
function addTransition() {
  const fromId = parseInt(document.getElementById('trans-from').value);
  const symbol = document.getElementById('trans-symbol').value.trim();
  const toId = parseInt(document.getElementById('trans-to').value);

  if (isNaN(fromId) || isNaN(toId) || !symbol) {
    alert('Please fill all fields'); return;
  }

  if (symbol !== 'ε' && symbol !== 'eps' && !/^[a-zA-Z0-9_\-\.]+$/.test(symbol)) {
    alert('Invalid symbol'); return;
  }

  const normalSym = (symbol === 'eps') ? 'ε' : symbol;

  // DFA check: exactly one transition per (state, symbol)
  if (mode === 'DFA') {
    const exists = transitions.find(t => t.from === fromId && t.symbol === normalSym);
    if (exists) {
      alert(`DFA already has a transition from ${states.find(s=>s.id===fromId)?.name} on "${normalSym}"`);
      return;
    }
  }

  // Prevent exact duplicate
  if (transitions.find(t => t.from === fromId && t.symbol === normalSym && t.to === toId)) {
    alert('Transition already exists'); return;
  }

  transitions.push({ from: fromId, symbol: normalSym, to: toId });
  document.getElementById('trans-symbol').value = '';
  renderGraph();
  updateUI();
}

function deleteTransition(from, symbol, to) {
  transitions = transitions.filter(t => !(t.from === from && t.symbol === symbol && t.to === to));
  renderGraph();
  updateUI();
}

// ================== ALPHABET ==================
function getAlphabet() {
  const syms = new Set();
  transitions.forEach(t => { if (t.symbol !== 'ε') syms.add(t.symbol); });
  return [...syms].sort();
}

// ================== D3 RENDER ==================
function renderGraph() {
  g.selectAll('*').remove();

  if (states.length === 0) {
    setStatus('Double-click canvas to add states · Use left panel for more options');
    return;
  }

  setStatus(`${states.length} state${states.length>1?'s':''} · ${transitions.length} transition${transitions.length!==1?'s':''} · Mode: ${mode}`);

  // Build edge groups (collapse parallel edges by from-to pair)
  const edgeMap = {};
  transitions.forEach(t => {
    const key = `${t.from}-${t.to}`;
    if (!edgeMap[key]) edgeMap[key] = { from: t.from, to: t.to, symbols: [] };
    edgeMap[key].symbols.push(t.symbol);
  });

  const R = 28; // node radius

  // Draw edges first
  Object.values(edgeMap).forEach(edge => {
    const fromState = states.find(s => s.id === edge.from);
    const toState = states.find(s => s.id === edge.to);
    if (!fromState || !toState) return;

    const isSelf = edge.from === edge.to;
    const revKey = `${edge.to}-${edge.from}`;
    const hasBidirectional = edgeMap[revKey] && edge.from !== edge.to;

    const label = edge.symbols.join(',');
    const isActive = isEdgeActive(edge);
    const edgeClass = isActive ? 'edge-active' : 'edge-normal';
    const edgeColor = isActive ? '#6c7fff' : '#3a4060';
    const markerStr = isActive ? 'url(#arrow-active)' : 'url(#arrow)';

    let pathEl;

    if (isSelf) {
      // Self-loop
      const lx = fromState.x;
      const ly = fromState.y - R;
      const cx1 = lx - 40, cy1 = ly - 50;
      const cx2 = lx + 40, cy2 = ly - 50;
      pathEl = g.append('path')
        .attr('d', `M${lx-10},${ly} C${cx1},${cy1} ${cx2},${cy2} ${lx+10},${ly}`)
        .attr('fill', 'none')
        .attr('stroke', edgeColor)
        .attr('stroke-width', isActive ? 2.5 : 1.5)
        .attr('marker-end', markerStr);

      // Label
      g.append('rect')
        .attr('x', lx - 16).attr('y', ly - 72)
        .attr('width', label.length * 7 + 8).attr('height', 16)
        .attr('rx', 3).attr('fill', '#0d0f14').attr('opacity', 0.9);
      g.append('text')
        .attr('x', lx).attr('y', ly - 63)
        .attr('text-anchor', 'middle')
        .attr('fill', isActive ? '#6c7fff' : '#9098b8')
        .attr('font-size', '11')
        .attr('font-family', 'JetBrains Mono, monospace')
        .text(label);

    } else if (hasBidirectional) {
      // Curved bidirectional
      const dx = toState.x - fromState.x;
      const dy = toState.y - fromState.y;
      const len = Math.sqrt(dx*dx+dy*dy);
      const nx = -dy/len, ny = dx/len;
      const curve = 30;
      const mx = (fromState.x+toState.x)/2 + nx*curve;
      const my = (fromState.y+toState.y)/2 + ny*curve;

      const angle = Math.atan2(toState.y - my, toState.x - mx);
      const ex = toState.x - R * Math.cos(angle);
      const ey = toState.y - R * Math.sin(angle);

      const startAngle = Math.atan2(fromState.y - my, fromState.x - mx);
      const sx = fromState.x - R * Math.cos(startAngle);
      const sy = fromState.y - R * Math.sin(startAngle);

      pathEl = g.append('path')
        .attr('d', `M${sx},${sy} Q${mx},${my} ${ex},${ey}`)
        .attr('fill', 'none')
        .attr('stroke', edgeColor)
        .attr('stroke-width', isActive ? 2.5 : 1.5)
        .attr('marker-end', markerStr);

      g.append('rect')
        .attr('x', mx - label.length*3.5 - 4).attr('y', my - 10)
        .attr('width', label.length*7+8).attr('height', 16)
        .attr('rx', 3).attr('fill', '#0d0f14').attr('opacity', 0.9);
      g.append('text')
        .attr('x', mx).attr('y', my)
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('fill', isActive ? '#6c7fff' : '#9098b8')
        .attr('font-size', '11').attr('font-family', 'JetBrains Mono, monospace')
        .text(label);

    } else {
      // Straight edge
      const dx = toState.x - fromState.x;
      const dy = toState.y - fromState.y;
      const len = Math.sqrt(dx*dx+dy*dy);
      const ux = dx/len, uy = dy/len;
      const sx = fromState.x + R * ux;
      const sy = fromState.y + R * uy;
      const ex = toState.x - R * ux;
      const ey = toState.y - R * uy;

      pathEl = g.append('line')
        .attr('x1', sx).attr('y1', sy).attr('x2', ex).attr('y2', ey)
        .attr('stroke', edgeColor)
        .attr('stroke-width', isActive ? 2.5 : 1.5)
        .attr('marker-end', markerStr);

      const mx = (sx+ex)/2, my = (sy+ey)/2;
      const nx = -uy, ny = ux;
      const lx = mx + nx*14, ly = my + ny*14;

      g.append('rect')
        .attr('x', lx - label.length*3.5 - 4).attr('y', ly - 10)
        .attr('width', label.length*7+8).attr('height', 16)
        .attr('rx', 3).attr('fill', '#0d0f14').attr('opacity', 0.9);
      g.append('text')
        .attr('x', lx).attr('y', ly)
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('fill', isActive ? '#6c7fff' : '#9098b8')
        .attr('font-size', '11').attr('font-family', 'JetBrains Mono, monospace')
        .text(label);
    }
  });

  // Draw start arrow for start state
  const startState = states.find(s => s.isStart);
  if (startState) {
    g.append('line')
      .attr('x1', startState.x - R - 35).attr('y1', startState.y)
      .attr('x2', startState.x - R - 2).attr('y2', startState.y)
      .attr('stroke', '#6c7fff').attr('stroke-width', 2)
      .attr('marker-end', 'url(#arrow-start)');
    g.append('text')
      .attr('x', startState.x - R - 38).attr('y', startState.y - 5)
      .attr('text-anchor', 'end')
      .attr('fill', '#6c7fff').attr('font-size', '10')
      .attr('font-family', 'JetBrains Mono, monospace')
      .text('start');
  }

  // Draw nodes
  states.forEach(state => {
    const isCurrent = isStateCurrent(state.id);
    const nodeGroup = g.append('g')
      .attr('class', 'node-group')
      .attr('transform', `translate(${state.x},${state.y})`)
      .style('cursor', 'grab');

    // Glow for current state
    if (isCurrent) {
      nodeGroup.append('circle')
        .attr('r', R + 8)
        .attr('fill', 'none')
        .attr('stroke', '#fbbf24')
        .attr('stroke-width', 1)
        .attr('opacity', 0.3);
    }

    // Outer accept ring
    if (state.isAccept) {
      nodeGroup.append('circle')
        .attr('r', R + 5)
        .attr('fill', 'none')
        .attr('stroke', isCurrent ? '#fbbf24' : '#4ade80')
        .attr('stroke-width', 1.5)
        .attr('opacity', isCurrent ? 0.8 : 0.6);
    }

    // Main circle
    let fillColor = '#1c2030';
    let strokeColor = '#363d58';
    let strokeWidth = 2;

    if (isCurrent) {
      fillColor = 'rgba(251,191,36,0.12)';
      strokeColor = '#fbbf24';
      strokeWidth = 2.5;
    } else if (state.isStart && state.isAccept) {
      fillColor = 'rgba(74,222,128,0.1)';
      strokeColor = '#4ade80';
    } else if (state.isStart) {
      fillColor = 'rgba(108,127,255,0.1)';
      strokeColor = '#6c7fff';
    } else if (state.isAccept) {
      fillColor = 'rgba(74,222,128,0.1)';
      strokeColor = '#4ade80';
    }

    nodeGroup.append('circle')
      .attr('r', R)
      .attr('fill', fillColor)
      .attr('stroke', strokeColor)
      .attr('stroke-width', strokeWidth);

    // Label
    nodeGroup.append('text')
      .attr('text-anchor', 'middle')
      .attr('dominant-baseline', 'central')
      .attr('fill', isCurrent ? '#fbbf24' : '#e8eaf6')
      .attr('font-size', state.name.length > 3 ? '10' : '13')
      .attr('font-weight', '500')
      .attr('font-family', 'JetBrains Mono, monospace')
      .text(state.name);

    // Drag behavior
    nodeGroup.call(d3.drag()
      .on('start', function(event) { d3.select(this).style('cursor', 'grabbing'); })
      .on('drag', function(event) {
        state.x = event.x;
        state.y = event.y;
        renderGraph();
      })
      .on('end', function(event) { d3.select(this).style('cursor', 'grab'); })
    );

    // Click to select/edit
    nodeGroup.on('click', function(event) {
      event.stopPropagation();
      selectState(state.id);
    });

    nodeGroup.on('dblclick', function(event) {
      event.stopPropagation();
      openEditState(state.id);
    });

    // Tooltip on hover
    nodeGroup.on('mouseenter', function(event) {
      let info = `State: ${state.name}`;
      if (state.isStart) info += '\n▶ Start state';
      if (state.isAccept) info += '\n✓ Accepting state';
      const out = transitions.filter(t => t.from === state.id);
      if (out.length) info += `\n${out.length} outgoing transition${out.length>1?'s':''}`;
      showTooltip(event, info);
    }).on('mousemove', function(event) {
      moveTooltip(event);
    }).on('mouseleave', function() {
      hideTooltip();
    });
  });
}

function isStateCurrent(id) {
  if (!simActive && simStep === 0) return false;
  if (mode === 'DFA') return dfaCurrentState === id;
  return nfaCurrentStates.has(id);
}

function isEdgeActive(edge) {
  if (!simActive && simStep === 0) return false;
  if (simStep <= 0) return false;
  // Check last log entry
  if (simLog.length === 0) return false;
  const last = simLog[simLog.length - 1];
  if (!last) return false;
  if (mode === 'DFA') {
    return last.from === edge.from && last.symbol === edge.symbols[0] && edge.symbols.includes(last.symbol);
  }
  return false;
}

function selectState(id) {
  selectedState = id;
  updateStatesList();
}

// ================== UI UPDATE ==================
function updateUI() {
  updateStatesList();
  updateTransitionSelects();
  updateTransitionsList();
  updateAlphabetDisplay();
}

function updateStatesList() {
  const el = document.getElementById('states-list');
  if (states.length === 0) {
    el.innerHTML = '<div class="empty-state"><div class="empty-state-icon">◯</div><div>No states yet</div></div>';
    return;
  }

  el.innerHTML = states.map(s => {
    const isCurrent = isStateCurrent(s.id);
    const dotClass = `state-dot${s.isStart?' start':''}${s.isAccept?' accept':''}${isCurrent?' current':''}`;
    return `
      <div class="state-item${s.id===selectedState?' selected':''}" onclick="selectState(${s.id})">
        <div class="${dotClass}"></div>
        <span class="state-name">${s.name}</span>
        <div class="state-badges">
          ${s.isStart?'<span class="badge badge-start">S</span>':''}
          ${s.isAccept?'<span class="badge badge-accept">F</span>':''}
        </div>
        <div class="state-actions">
          <button class="icon-btn" title="Edit" onclick="event.stopPropagation();openEditState(${s.id})">✏</button>
          <button class="icon-btn" title="Toggle start" onclick="event.stopPropagation();toggleStart(${s.id})">▶</button>
          <button class="icon-btn" title="Toggle accept" onclick="event.stopPropagation();toggleAccept(${s.id})">✓</button>
          <button class="icon-btn danger" title="Delete" onclick="event.stopPropagation();deleteState(${s.id})">✕</button>
        </div>
      </div>
    `;
  }).join('');
}

function updateTransitionSelects() {
  const fromSel = document.getElementById('trans-from');
  const toSel = document.getElementById('trans-to');
  const opts = states.map(s => `<option value="${s.id}">${s.name}</option>`).join('');
  fromSel.innerHTML = opts || '<option value="">-- add states first --</option>';
  toSel.innerHTML = opts || '<option value="">-- add states first --</option>';
}

function updateTransitionsList() {
  const el = document.getElementById('transitions-list');
  if (transitions.length === 0) {
    el.innerHTML = '<div class="empty-state"><div class="empty-state-icon">→</div><div>No transitions yet</div></div>';
    return;
  }

  const rows = transitions.map(t => {
    const fromName = states.find(s => s.id === t.from)?.name || '?';
    const toName = states.find(s => s.id === t.to)?.name || '?';
    const symDisplay = t.symbol === 'ε' ? `<span style="color:var(--purple)">ε</span>` : `<span class="trans-cell-symbol">${t.symbol}</span>`;
    return `<tr>
      <td class="trans-cell-state">${fromName}</td>
      <td>${symDisplay}</td>
      <td class="trans-cell-next">${toName}</td>
      <td class="del-trans" onclick="deleteTransition(${t.from},'${t.symbol}',${t.to})" title="Delete">✕</td>
    </tr>`;
  }).join('');

  el.innerHTML = `<table class="trans-table">
    <thead><tr><th>From</th><th>On</th><th>To</th><th></th></tr></thead>
    <tbody>${rows}</tbody>
  </table>`;
}

function updateAlphabetDisplay() {
  const el = document.getElementById('alphabet-display');
  const alpha = getAlphabet();
  const hasEps = transitions.some(t => t.symbol === 'ε');

  if (alpha.length === 0 && !hasEps) {
    el.innerHTML = '<span class="info-text">Add transitions to build alphabet</span>';
    return;
  }

  let html = alpha.map(s => `<span class="pill">${s}</span>`).join('');
  if (hasEps) html += `<span class="pill eps">ε</span>`;
  el.innerHTML = html;
}

// ================== SIMULATION ==================
function runSim() {
  const input = document.getElementById('sim-input').value;
  simInput = input;
  simStep = 0;
  simLog = [];
  simActive = true;

  document.getElementById('result-box').className = 'result-box';
  document.getElementById('trace-log').innerHTML = '';
  document.getElementById('nfa-current-states').classList.add('hidden');
  document.getElementById('eps-closure-box').classList.remove('visible');

  if (states.length === 0) { alert('No states defined'); return; }
  const startState = states.find(s => s.isStart);
  if (!startState) { alert('No start state defined'); return; }

  // Validate alphabet (skip epsilon)
  const alpha = getAlphabet();
  if (alpha.length > 0) {
    for (const ch of input) {
      if (!alpha.includes(ch)) {
        document.getElementById('sim-input').classList.add('error');
        setTimeout(() => document.getElementById('sim-input').classList.remove('error'), 1000);
        alert(`Character "${ch}" not in alphabet {${alpha.join(', ')}}`);
        return;
      }
    }
  }

  if (mode === 'DFA') {
    dfaCurrentState = startState.id;
    nfaCurrentStates = new Set();
  } else {
    // NFA: start with ε-closure of start state
    nfaCurrentStates = epsClosure(new Set([startState.id]));
    dfaCurrentState = null;
    showNFAStates();
  }

  updateProgress(-1);
  addTraceEntry({ type: 'start', state: startState.name, nfaStates: [...nfaCurrentStates].map(id => states.find(s=>s.id===id)?.name) });

  document.getElementById('btn-step').disabled = false;
  document.getElementById('btn-autoplay').disabled = false;
  document.getElementById('btn-reset').disabled = false;

  renderGraph();
  updateStatesList();

  setStatus(`Simulation started · Input: "${input}" · ${input.length} symbol${input.length!==1?'s':''}`);
}

function stepSim() {
  if (!simActive) return;
  if (simStep >= simInput.length) { finishSim(); return; }

  const sym = simInput[simStep];
  updateProgress(simStep);

  if (mode === 'DFA') {
    const trans = transitions.find(t => t.from === dfaCurrentState && t.symbol === sym);
    const fromName = states.find(s => s.id === dfaCurrentState)?.name || '?';

    if (!trans) {
      simLog.push({ from: dfaCurrentState, symbol: sym, to: null });
      addTraceEntry({ type: 'dead', symbol: sym, from: fromName });
      dfaCurrentState = null;
      simStep = simInput.length; // end
      finishSim();
      return;
    }

    simLog.push({ from: trans.from, symbol: sym, to: trans.to });
    const toName = states.find(s => s.id === trans.to)?.name || '?';
    addTraceEntry({ type: 'step', symbol: sym, from: fromName, to: toName });
    dfaCurrentState = trans.to;

  } else {
    // NFA
    const newStates = new Set();
    const fromNames = [...nfaCurrentStates].map(id => states.find(s=>s.id===id)?.name);
    const moveResult = move(nfaCurrentStates, sym);
    const newClosure = epsClosure(moveResult);

    addTraceEntry({ type: 'nfa-step', symbol: sym, fromStates: fromNames, toStates: [...newClosure].map(id=>states.find(s=>s.id===id)?.name) });
    nfaCurrentStates = newClosure;
    showNFAStates();

    // Show epsilon closure if there were epsilon transitions
    const epsTransExist = transitions.some(t => t.symbol === 'ε');
    if (epsTransExist) {
      showEpsClosure([...newClosure].map(id => states.find(s=>s.id===id)?.name));
    }
  }

  simStep++;
  if (simStep >= simInput.length) {
    finishSim();
    return;
  }

  renderGraph();
  updateStatesList();
}

function finishSim() {
  updateProgress(simInput.length);

  let accepted = false;
  let finalStates = [];

  if (mode === 'DFA') {
    if (dfaCurrentState !== null) {
      const s = states.find(st => st.id === dfaCurrentState);
      accepted = s?.isAccept || false;
      if (s) finalStates = [s.name];
    }
  } else {
    // NFA: accepted if any current state is accepting
    finalStates = [...nfaCurrentStates]
      .map(id => states.find(s=>s.id===id))
      .filter(s => s?.isAccept)
      .map(s => s.name);
    accepted = finalStates.length > 0;
  }

  const resultBox = document.getElementById('result-box');
  const resultLabel = document.getElementById('result-label');
  const resultDetail = document.getElementById('result-detail');

  resultBox.className = `result-box ${accepted ? 'accepted' : 'rejected'}`;
  resultLabel.className = `result-label ${accepted ? 'accepted' : 'rejected'}`;
  resultLabel.textContent = accepted ? '✓ ACCEPTED' : '✗ REJECTED';
  resultDetail.textContent = accepted
    ? `Final state${finalStates.length>1?'s':''}: {${finalStates.join(', ')}}`
    : `String "${simInput}" rejected${mode==='DFA'&&dfaCurrentState===null?' — dead state':' — no accepting state reached'}`;

  addTraceEntry({ type: accepted ? 'accept' : 'reject', finalStates });

  stopAutoplay();
  document.getElementById('btn-step').disabled = true;
  document.getElementById('btn-autoplay').disabled = true;

  renderGraph();
  updateStatesList();

  setStatus(accepted ? `✓ Accepted · Final: {${finalStates.join(', ')}}` : `✗ Rejected · String not in language`);
}

function resetSim() {
  stopAutoplay();
  simActive = false;
  simStep = 0;
  simLog = [];
  dfaCurrentState = null;
  nfaCurrentStates = new Set();

  document.getElementById('result-box').className = 'result-box';
  document.getElementById('trace-log').innerHTML = '<div class="empty-state"><div class="empty-state-icon">⌛</div><div>No simulation yet</div></div>';
  document.getElementById('sim-progress').innerHTML = '';
  document.getElementById('btn-step').disabled = true;
  document.getElementById('btn-autoplay').disabled = true;
  document.getElementById('btn-reset').disabled = true;
  document.getElementById('nfa-current-states').classList.add('hidden');
  document.getElementById('eps-closure-box').classList.remove('visible');

  renderGraph();
  updateStatesList();
  setStatus(`${states.length} state${states.length!==1?'s':''} · ${transitions.length} transition${transitions.length!==1?'s':''} · Mode: ${mode}`);
}

function toggleAutoplay() {
  if (autoplayTimer) {
    stopAutoplay();
  } else {
    document.getElementById('btn-autoplay').textContent = '⏸ Pause';
    document.getElementById('btn-autoplay').classList.add('btn-red');
    const speed = parseInt(document.getElementById('speed-slider').value);
    const delay = [800, 600, 400, 250, 120][speed - 1];
    autoplayTimer = setInterval(() => {
      if (simStep >= simInput.length) { stopAutoplay(); finishSim(); return; }
      stepSim();
    }, delay);
  }
}

function stopAutoplay() {
  if (autoplayTimer) {
    clearInterval(autoplayTimer);
    autoplayTimer = null;
  }
  const btn = document.getElementById('btn-autoplay');
  btn.textContent = '▶ Play';
  btn.classList.remove('btn-red');
}

// ================== NFA ENGINE ==================
function epsClosure(stateSet) {
  const closure = new Set(stateSet);
  const stack = [...stateSet];

  while (stack.length > 0) {
    const s = stack.pop();
    const epsTrans = transitions.filter(t => t.from === s && t.symbol === 'ε');
    epsTrans.forEach(t => {
      if (!closure.has(t.to)) {
        closure.add(t.to);
        stack.push(t.to);
      }
    });
  }

  return closure;
}

function move(stateSet, symbol) {
  const result = new Set();
  stateSet.forEach(s => {
    transitions.filter(t => t.from === s && t.symbol === symbol)
      .forEach(t => result.add(t.to));
  });
  return result;
}

function showNFAStates() {
  const el = document.getElementById('nfa-current-states');
  if (mode !== 'NFA') { el.classList.add('hidden'); return; }
  el.classList.remove('hidden');

  const stateNames = [...nfaCurrentStates].map(id => {
    const s = states.find(st => st.id === id);
    return { name: s?.name || '?', isAccept: s?.isAccept || false };
  });

  el.innerHTML = '<div style="font-size:10px;color:var(--text3);margin-bottom:4px;font-family:JetBrains Mono,monospace;">Active states:</div>' +
    stateNames.map(s => `<span class="nfa-state-pill${s.isAccept?' accepting':''}">${s.name}</span>`).join('');
}

function showEpsClosure(names) {
  const el = document.getElementById('eps-closure-box');
  document.getElementById('eps-closure-content').textContent = `{${names.join(', ')}}`;
  el.classList.add('visible');
}

// ================== TRACE LOG ==================
function addTraceEntry(entry) {
  const log = document.getElementById('trace-log');
  if (log.querySelector('.empty-state')) log.innerHTML = '';

  const div = document.createElement('div');
  div.className = 'trace-entry';

  let content = '';
  const step = simStep;

  if (entry.type === 'start') {
    if (mode === 'DFA') {
      content = `<span class="trace-state">${entry.state}</span> <span style="color:var(--text3)">← start</span>`;
    } else {
      content = `ε-closure: {<span class="trace-state">${(entry.nfaStates||[]).join(', ')}</span>} <span style="color:var(--text3)">← start</span>`;
    }
  } else if (entry.type === 'step') {
    content = `<span class="trace-state">${entry.from}</span> <span style="color:var(--text3)">─</span><span class="trace-sym">${entry.symbol}</span><span style="color:var(--text3)">→</span> <span class="trace-next">${entry.to}</span>`;
  } else if (entry.type === 'nfa-step') {
    content = `{<span class="trace-state">${(entry.fromStates||[]).join(', ')}</span>} <span style="color:var(--text3)">─</span><span class="trace-sym">${entry.symbol}</span><span style="color:var(--text3)">→</span> {<span class="trace-next">${(entry.toStates||[]).join(', ')}</span>}`;
  } else if (entry.type === 'dead') {
    content = `<span class="trace-state">${entry.from}</span> <span style="color:var(--text3)">─</span><span class="trace-sym">${entry.symbol}</span><span style="color:var(--text3)">→</span> <span class="trace-reject">∅ (dead)</span>`;
  } else if (entry.type === 'accept') {
    content = `<span class="trace-next">✓ ACCEPTED</span> <span style="color:var(--text3)">in {${entry.finalStates.join(', ')}}</span>`;
  } else if (entry.type === 'reject') {
    content = `<span class="trace-reject">✗ REJECTED</span>`;
  }

  div.innerHTML = `<span class="trace-step">${step}</span><span class="trace-content">${content}</span>`;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

// ================== PROGRESS ==================
function updateProgress(currentIdx) {
  const el = document.getElementById('sim-progress');
  if (simInput.length === 0) { el.innerHTML = '<span class="info-text">ε (empty string)</span>'; return; }

  el.innerHTML = simInput.split('').map((ch, i) => {
    let cls = '';
    if (i < currentIdx) cls = 'done';
    else if (i === currentIdx) cls = 'active';
    return `<span class="progress-sym ${cls}">${ch}</span>`;
  }).join('');
}

